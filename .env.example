# ─── Production (Railway) ─────────────────────────────────────────────────────
# Set these in Railway > Variables tab

# DATABASE_URL=jdbc:postgresql://host:5432/railway   ← Railway fills automatically
# REDIS_URL=redis://default:password@host:6379        ← Railway fills automatically
# JWT_SECRET=<run: openssl rand -base64 64>
# SPRING_PROFILES_ACTIVE=prod
# APP_BASE_URL=https://your-app.vercel.app            ← your Vercel frontend URL
# app.cors.allowed-origins=https://your-app.vercel.app

# ─── Mail (optional) ──────────────────────────────────────────────────────────
